# Copy to .env and fill in your keys. Never commit .env.

# Frontend (Vite): Stripe publishable key only
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
VITE_ESCROW_API_KEY=

# Server (node server/index.js): secret keys – do not expose
STRIPE_SECRET_KEY=sk_test_xxxxx
ESCROW_EMAIL=your@email.com
ESCROW_API_KEY=your-escrow-api-key
# Use Escrow sandbox (1 = sandbox, omit or 0 = live)
ESCROW_SANDBOX=1
API_PORT=3001

# Role invitation emails (Nodemailer). Leave SMTP_HOST empty to simulate only (logs to API terminal).
# Restart `npm run server` after changing these.
#
# PUBLIC_APP_URL = link in the email (use your deployed URL for real invitees; localhost only works on your PC).
PUBLIC_APP_URL=http://localhost:5173
#
# --- Gmail (use an App Password, not your normal password): https://support.google.com/accounts/answer/185833
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=you@gmail.com
#
# --- SendGrid SMTP: https://docs.sendgrid.com/for-developers/sending-email/getting-started-smtp
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=<your SendGrid API key>
# SMTP_FROM=verified-sender@yourdomain.com
#
SMTP_HOST=
SMTP_PORT=587
# Set to 1 only for port 465 (implicit TLS). Leave empty for 587 STARTTLS.
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
# Optional "From" (defaults to SMTP_USER). Must be allowed by your provider.
SMTP_FROM=
# Set to 1 for verbose SMTP wire logs in the API terminal
SMTP_DEBUG=
